# Sourced by scripts/apply-branding.sh. Empty value = skip that setting (idempotent).
# Navbar logo URL is web path /logos/... (files: branding/docroot/logos/... on host -> /dv/docroot/logos/... in container).
# For :HeaderCustomizationFile / :FooterCustomizationFile / :StyleCustomizationFile use *filesystem* paths in the
# API, e.g. /dv/docroot/branding/custom-header.html (see branding.env examples below).

INSTALLATION_NAME='DataverseUp'

# Navbar logo file on disk: branding/docroot/logos/navbar/logo.svg → URL below (must match filename).
LOGO_CUSTOMIZATION_FILE=/logos/navbar/logo.svg

# Hide the root Dataverse *theme* header (big banner). That block uses a different image URL
# (/logos/<dataverse-id>/<theme-logo-filename>) and often shows a broken icon if that file is missing.
# Recommended when using LOGO_CUSTOMIZATION_FILE so you are not looking at two different logos.
DISABLE_ROOT_DATAVERSE_THEME=true

# Uncomment when you add files under branding/docroot/branding/ (use /dv/docroot/... paths for the servlet)
# HEADER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-header.html
# HOME_PAGE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-homepage.html
# FOOTER_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-footer.html
# STYLE_CUSTOMIZATION_FILE=/dv/docroot/branding/custom-stylesheet.css

# Multi-word values must be quoted. FOOTER_COPYRIGHT is appended to the built-in "Copyright © YEAR" with no
# separator in the UI; apply-branding.sh prepends a space unless you start with space/tab, —, -, |, or (.
FOOTER_COPYRIGHT=' DataverseUp | Hosted by <a href="https://notch8.com" rel="noopener noreferrer">Notch8</a>, your partner in digital preservation.'

NAVBAR_ABOUT_URL=https://notch8.com/about
NAVBAR_SUPPORT_URL=mailto:support@notch8.com
NAVBAR_GUIDES_URL=https://guides.dataverse.org/en/latest/
