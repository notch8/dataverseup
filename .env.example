# Copy to .env and customize. Do not commit .env.
# docker compose loads this for interpolation and passes it into containers (see docker-compose.yml).

VERSION=6.10.1-noble-r0
DOCKER_HUB=gdcc/dataverse
CONFIGURATION_PATH=.

DATAVERSE_DB_HOST=postgres
DATAVERSE_DB_USER=dataverse
DATAVERSE_DB_PASSWORD=dvnsecret
DATAVERSE_DB_NAME=dataverse

SOLR_SERVICE_HOST=solr:8983
SOLR_SERVICE_PORT=8983
# Used by init.d scripts inside the Dataverse container (curl to localhost:8080).
DATAVERSE_URL=localhost:8080
DATAVERSE_SERVICE_HOST=localhost

POSTGRES_USER=dataverse
POSTGRES_PASSWORD=dvnsecret
POSTGRES_SERVER=postgres
POSTGRES_DATABASE=dataverse
POSTGRES_DB=dataverse
POSTGRES_PORT=5432

hostname=localhost
traefikhost=localhost
INIT_SCRIPTS_FOLDER=/opt/payara/init.d

# For Traefik ACME (real DNS hostname). For pure localhost demos, value is unused.
useremail=you@example.org

WEBHOOK=/opt/payara/triggers/external-services.py

# Optional: DataCite test (leave as-is for FAKE DOIs via bootstrap / init.d)
dataciterestapiurlstring=https\\:\/\/api.test.datacite.org
baseurlstring=https\:\/\/mds.test.datacite.org

# Optional builtin-user API key override (see init.d/01-persistent-id.sh)
# BUILTIN_USERS_KEY=burrito

# --- Optional: MinIO buckets (only if init.d minio scripts should run) ---
# minio_label_1=
# bucketname_1=
# minio_bucket_1=
# minio_profile_1=

# --- Optional: AWS S3 store (only if init.d/006-s3-aws-storage.sh should run) ---
# aws_bucket_name=
# aws_endpoint_url=
# aws_s3_profile=
